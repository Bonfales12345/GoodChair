<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <!-- Widget Container -->
    <FrameLayout
        android:id="@+id/widget_wrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/widget_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:orientation="vertical"
            android:padding="8dp" />

        <!-- Overlay for resize handles -->
        <FrameLayout
            android:id="@+id/resize_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Workspace for pinned apps - Using ViewPager2 for pages -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/workspace_viewpager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/dock_container"
        app:layout_constraintTop_toBottomOf="@id/widget_wrapper" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/dock_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Background for blur - explicit height -->
        <View
            android:id="@+id/dock_blur_background"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#33FFFFFF" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/dock_list"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:paddingHorizontal="12dp"
            android:orientation="horizontal" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>